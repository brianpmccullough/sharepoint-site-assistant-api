PORT=3000

# Azure AD / Microsoft identity settings
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-client-id
AZURE_CLIENT_SECRET=your-client-id-secret-value #store in a vault
TENANT_NAME=myco #used for CORS, among others

# AI provider — openai | azure (defaults to openai)
AI_PROVIDER=openai

# OpenAI settings (required when AI_PROVIDER=openai)
OPENAI_API_KEY=your-openai-api-key #store in a vault
OPENAI_MODEL=gpt-4o-mini #optional, defaults to gpt-4o-mini

# Azure AI settings (required when AI_PROVIDER=azure)
# Works with both Azure OpenAI Service and Azure AI Foundry model deployments
AZURE_AI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_AI_API_KEY=your-azure-ai-api-key #store in a vault
AZURE_AI_DEPLOYMENT=your-deployment-name
AZURE_AI_API_VERSION=2025-01-01-preview #optional, defaults to 2025-01-01-preview
